generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AuthUserRole {
  CHIEF_ACCOUNTANT
  STAFF_ACCOUNTANT
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

enum PartnerType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum ItemType {
  GOODS
  SERVICE
  MATERIAL
  OTHER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  OFF_BALANCE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

enum ReminderScope {
  AR
  AP
  BOTH
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum JournalRefType {
  SALES_INVOICE
  RECEIPT
  PURCHASE_INVOICE
  PAYMENT
  OPENING_BALANCE
}

enum PeriodStatus {
  OPEN
  CLOSED
}

model UserProfile {
  id              String       @id @db.Uuid
  email           String       @unique @db.VarChar(255)
  fullName        String?      @map("full_name") @db.VarChar(120)
  role            AuthUserRole @default(STAFF_ACCOUNTANT)
  provider        AuthProvider @default(EMAIL)
  avatarUrl       String?      @map("avatar_url")
  isEmailVerified Boolean      @default(false) @map("is_email_verified")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  auditLogs              AuthAuditLog[]
  voucherAuditLogs       VoucherAuditLog[]
  postedSalesInvoices    SalesInvoice[]     @relation("SalesInvoicePostedBy")
  postedPurchaseInvoices PurchaseInvoice[]  @relation("PurchaseInvoicePostedBy")
  createdJournalEntries  JournalEntry[]     @relation("JournalCreatedBy")
  createdReceipts        Receipt[]          @relation("ReceiptCreatedBy")
  createdPayments        Payment[]          @relation("PaymentCreatedBy")
  closedPeriods          AccountingPeriod[] @relation("PeriodClosedBy")

  @@map("user_profiles")
}

model AuthAuditLog {
  id        BigInt        @id @default(autoincrement())
  userId    String?       @map("user_id") @db.Uuid
  email     String?       @db.VarChar(255)
  action    String        @db.VarChar(50)
  success   Boolean
  message   String?
  provider  AuthProvider?
  role      AuthUserRole?
  ipAddress String?       @map("ip_address") @db.VarChar(64)
  createdAt DateTime      @default(now()) @map("created_at")

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([action])
  @@index([createdAt])
  @@map("auth_audit_logs")
}

model VoucherAuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  userEmail  String?  @map("user_email") @db.VarChar(255)
  userName   String?  @map("user_name") @db.VarChar(255)
  action     String   @db.VarChar(50)
  entityType String   @default("SALES_INVOICE") @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  entityRef  String?  @map("entity_ref") @db.VarChar(100)
  detail     String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("voucher_audit_logs")
}

model Partner {
  id                String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String               @unique @db.VarChar(30)
  name              String               @db.VarChar(180)
  partnerType       PartnerType          @default(BOTH) @map("partner_type")
  taxCode           String?              @map("tax_code") @db.VarChar(30)
  phone             String?              @db.VarChar(30)
  email             String?              @db.VarChar(255)
  address           String?
  paymentTermDays   Int?                 @map("payment_term_days")
  creditLimit       Decimal?             @map("credit_limit") @db.Decimal(18, 2)
  isActive          Boolean              @default(true) @map("is_active")
  debtReminderOn    Boolean              @default(true) @map("debt_reminder_on")
  reminderEmail     String?              @map("reminder_email") @db.VarChar(255)
  reminderCcEmails  Json?                @map("reminder_cc_emails")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  debtReminders     DebtReminderConfig[]
  debtReminderLogs  DebtReminderLog[]
  salesInvoices     SalesInvoice[]       @relation("SalesInvoiceCustomer")
  purchaseInvoices  PurchaseInvoice[]    @relation("PurchaseInvoiceSupplier")
  journalEntryLines JournalEntryLine[]   @relation("JournalLinePartner")
  receipts          Receipt[]            @relation("ReceiptCustomer")
  payments          Payment[]            @relation("PaymentSupplier")

  @@index([name])
  @@index([partnerType])
  @@index([isActive])
  @@map("partners")
}

model Account {
  id                String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code              String                  @unique @db.VarChar(20)
  name              String                  @db.VarChar(180)
  accountType       AccountType             @map("account_type")
  normalBalance     NormalBalance           @map("normal_balance")
  parentId          String?                 @map("parent_id") @db.Uuid
  level             Int                     @default(1)
  isPosting         Boolean                 @default(true) @map("is_posting")
  allowManualEntry  Boolean                 @default(true) @map("allow_manual_entry")
  isActive          Boolean                 @default(true) @map("is_active")
  sortOrder         Int                     @default(0) @map("sort_order")
  description       String?
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  parent            Account?                @relation("AccountTree", fields: [parentId], references: [id], onDelete: SetNull)
  children          Account[]               @relation("AccountTree")
  revenueItems      Item[]                  @relation("RevenueAccount")
  cogsItems         Item[]                  @relation("CogsAccount")
  inventoryItems    Item[]                  @relation("InventoryAccount")
  arAccountDetails  SalesInvoiceDetail[]    @relation("ArAccount")
  revAccountDetails SalesInvoiceDetail[]    @relation("RevAccount")
  apAccountDetails  PurchaseInvoiceDetail[] @relation("ApAccount")
  expAccountDetails PurchaseInvoiceDetail[] @relation("ExpAccount")
  journalEntryLines JournalEntryLine[]
  openingBalances   AccountOpeningBalance[]

  @@index([parentId])
  @@index([accountType])
  @@index([isActive])
  @@map("accounts")
}

model Item {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku                    String                  @unique @db.VarChar(40)
  name                   String                  @db.VarChar(180)
  itemType               ItemType                @default(GOODS) @map("item_type")
  unit                   String                  @db.VarChar(30)
  salePrice              Decimal?                @map("sale_price") @db.Decimal(18, 2)
  purchasePrice          Decimal?                @map("purchase_price") @db.Decimal(18, 2)
  vatRate                Decimal?                @map("vat_rate") @db.Decimal(5, 2)
  revenueAccountId       String?                 @map("revenue_account_id") @db.Uuid
  cogsAccountId          String?                 @map("cogs_account_id") @db.Uuid
  inventoryAccountId     String?                 @map("inventory_account_id") @db.Uuid
  isTrackedInventory     Boolean                 @default(false) @map("is_tracked_inventory")
  isActive               Boolean                 @default(true) @map("is_active")
  description            String?
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  revenueAccount         Account?                @relation("RevenueAccount", fields: [revenueAccountId], references: [id], onDelete: SetNull)
  cogsAccount            Account?                @relation("CogsAccount", fields: [cogsAccountId], references: [id], onDelete: SetNull)
  inventoryAccount       Account?                @relation("InventoryAccount", fields: [inventoryAccountId], references: [id], onDelete: SetNull)
  salesInvoiceDetails    SalesInvoiceDetail[]
  purchaseInvoiceDetails PurchaseInvoiceDetail[] @relation("PurchaseItem")

  @@index([name])
  @@index([itemType])
  @@index([isActive])
  @@map("items")
}

model DebtReminderConfig {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partnerId      String        @map("partner_id") @db.Uuid
  scope          ReminderScope @default(BOTH)
  enabled        Boolean       @default(true)
  daysBeforeDue  Int           @default(3) @map("days_before_due")
  daysAfterDue   Int           @default(1) @map("days_after_due")
  recipientEmail String?       @map("recipient_email") @db.VarChar(255)
  ccEmails       Json?         @map("cc_emails")
  lastSentAt     DateTime?     @map("last_sent_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  partner        Partner       @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([partnerId, scope])
  @@index([enabled])
  @@map("debt_reminder_configs")
}

model DebtReminderLog {
  id             BigInt         @id @default(autoincrement())
  partnerId      String         @map("partner_id") @db.Uuid
  scope          ReminderScope
  invoiceRef     String?        @map("invoice_ref") @db.VarChar(80)
  recipientEmail String         @map("recipient_email") @db.VarChar(255)
  subject        String         @db.VarChar(255)
  status         ReminderStatus @default(PENDING)
  errorMessage   String?        @map("error_message")
  scheduledAt    DateTime       @default(now()) @map("scheduled_at")
  sentAt         DateTime?      @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  partner        Partner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([status])
  @@index([scheduledAt])
  @@map("debt_reminder_logs")
}

// ─── System Settings (key-value store for runtime config) ────────────────────

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ─── Warehouse ────────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(120)
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesInvoiceDetails      SalesInvoiceDetail[]
  purchaseWarehouseDetails PurchaseInvoiceDetail[] @relation("PurchaseWarehouse")

  @@index([isActive])
  @@map("warehouses")
}

// ─── Sales Invoice ────────────────────────────────────────────────────────────

model SalesInvoice {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voucherNumber  String   @unique @map("voucher_number") @db.VarChar(30)
  voucherDate    DateTime @map("voucher_date") @db.Date
  accountingDate DateTime @map("accounting_date") @db.Date
  customerId     String   @map("customer_id") @db.Uuid
  description    String?

  // Amounts
  totalAmount Decimal @default(0) @map("total_amount") @db.Decimal(18, 2)
  vatAmount   Decimal @default(0) @map("vat_amount") @db.Decimal(18, 2)
  grandTotal  Decimal @default(0) @map("grand_total") @db.Decimal(18, 2)

  // Invoice info
  invoiceNumber String?       @map("invoice_number") @db.VarChar(30)
  invoiceSeries String?       @map("invoice_series") @db.VarChar(10)
  invoiceDate   DateTime?     @map("invoice_date") @db.Date
  invoiceStatus InvoiceStatus @default(DRAFT) @map("invoice_status")

  // Posting status
  isPosted   Boolean   @default(false) @map("is_posted")
  postedAt   DateTime? @map("posted_at")
  postedById String?   @map("posted_by_id") @db.Uuid

  // Flags
  isDelivered Boolean @default(false) @map("is_delivered") // Kiêm phiếu xuất kho
  isInvoiced  Boolean @default(false) @map("is_invoiced") // Lập kèm hóa đơn

  // Extra header fields
  contactPerson   String?   @map("contact_person") @db.VarChar(120)
  salesPersonName String?   @map("sales_person_name") @db.VarChar(120)
  reference       String?   @db.VarChar(80)
  paymentTermDays Int?      @map("payment_term_days")
  dueDate         DateTime? @map("due_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  customer       Partner              @relation("SalesInvoiceCustomer", fields: [customerId], references: [id])
  postedBy       UserProfile?         @relation("SalesInvoicePostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  details        SalesInvoiceDetail[]
  journalEntries JournalEntry[]

  @@index([voucherDate])
  @@index([accountingDate])
  @@index([customerId])
  @@index([invoiceStatus])
  @@index([isPosted])
  @@index([invoiceStatus, isPosted, customerId], name: "idx_si_status_posted_customer")
  @@index([customerId, invoiceStatus, isPosted, dueDate], name: "idx_si_customer_debt_query")
  @@map("sales_invoices")
}

// ─── Sales Invoice Detail ─────────────────────────────────────────────────────

model SalesInvoiceDetail {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  itemId      String  @map("item_id") @db.Uuid
  warehouseId String? @map("warehouse_id") @db.Uuid
  description String? @db.VarChar(255)
  qty         Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @map("unit_price") @db.Decimal(18, 2)
  vatRate     Decimal @default(0) @map("vat_rate") @db.Decimal(5, 2)
  amount      Decimal @db.Decimal(18, 2)

  // Accounts – defaults (131 / 511) applied at the application layer
  arAccountId  String? @map("ar_account_id") @db.Uuid
  revAccountId String? @map("rev_account_id") @db.Uuid

  sortOrder Int @default(0) @map("sort_order")

  invoice    SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item       Item         @relation(fields: [itemId], references: [id])
  warehouse  Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  arAccount  Account?     @relation("ArAccount", fields: [arAccountId], references: [id], onDelete: SetNull)
  revAccount Account?     @relation("RevAccount", fields: [revAccountId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([itemId])
  @@map("sales_invoice_details")
}

// ─── Journal Entry (Bút toán kép) ────────────────────────────────────────────

model JournalEntry {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entryNumber       String         @unique @map("entry_number") @db.VarChar(30)
  accountingDate    DateTime       @map("accounting_date") @db.Date
  description       String?
  refType           JournalRefType @map("ref_type")
  refId             String         @map("ref_id") @db.Uuid // polymorphic ref to source document
  salesInvoiceId    String?        @map("sales_invoice_id") @db.Uuid // typed FK for query convenience
  purchaseInvoiceId String?        @map("purchase_invoice_id") @db.Uuid
  isReversed        Boolean        @default(false) @map("is_reversed")
  reversedById      String?        @map("reversed_by_id") @db.Uuid // FK to the reversing entry
  createdById       String?        @map("created_by_id") @db.Uuid
  createdAt         DateTime       @default(now()) @map("created_at")

  salesInvoice    SalesInvoice?      @relation(fields: [salesInvoiceId], references: [id], onDelete: SetNull)
  purchaseInvoice PurchaseInvoice?   @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)
  createdBy       UserProfile?       @relation("JournalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  reversedBy      JournalEntry?      @relation("JournalReversal", fields: [reversedById], references: [id], onDelete: SetNull)
  reversalOf      JournalEntry[]     @relation("JournalReversal")
  lines           JournalEntryLine[]
  receipt         Receipt?           @relation("ReceiptJournal")
  payment         Payment?           @relation("PaymentJournal")

  @@index([accountingDate])
  @@index([refType, refId])
  @@index([salesInvoiceId])
  @@index([purchaseInvoiceId])
  @@map("journal_entries")
}

// ─── Journal Entry Line (Chi tiết Nợ/Có) ─────────────────────────────────────

model JournalEntryLine {
  id             BigInt  @id @default(autoincrement())
  journalEntryId String  @map("journal_entry_id") @db.Uuid
  accountId      String  @map("account_id") @db.Uuid
  debitAmount    Decimal @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount   Decimal @default(0) @map("credit_amount") @db.Decimal(18, 2)
  description    String? @db.VarChar(255)
  partnerId      String? @map("partner_id") @db.Uuid // tracing dimension (131/331 sub-ledger)
  sortOrder      Int     @default(0) @map("sort_order")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])
  partner      Partner?     @relation("JournalLinePartner", fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([journalEntryId])
  @@index([accountId])
  @@index([partnerId])
  @@index([partnerId, accountId], name: "idx_jel_partner_account")
  @@map("journal_entry_lines")
}

// ─── Invoice Setting (Dải hóa đơn) ───────────────────────────────────────────

model InvoiceSetting {
  id            String   @id @default(uuid()) @db.Uuid
  year          Int
  symbol        String   @db.VarChar(20)
  templateCode  String   @default("1") @map("template_code") @db.VarChar(10)
  startNumber   Int      @default(1) @map("start_number")
  currentNumber Int      @default(0) @map("current_number")
  isActive      Boolean  @default(false) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([year, symbol], name: "uq_invoice_settings_year_symbol")
  @@index([year])
  @@map("invoice_settings")
}

// ─── Receipt (Phiếu thu tiền) ────────────────────────────────────────────────

model Receipt {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  receiptNumber  String   @unique @map("receipt_number") @db.VarChar(30)
  receiptDate    DateTime @map("receipt_date") @db.Date
  accountingDate DateTime @map("accounting_date") @db.Date
  customerId     String   @map("customer_id") @db.Uuid
  submitter      String?  @db.VarChar(120) // Người nộp
  reason         String?  @db.VarChar(255) // Lý do nộp
  totalAmount    Decimal  @default(0) @map("total_amount") @db.Decimal(18, 2)
  notes          String?
  journalEntryId String?  @unique @map("journal_entry_id") @db.Uuid
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  customer     Partner       @relation("ReceiptCustomer", fields: [customerId], references: [id])
  createdBy    UserProfile?  @relation("ReceiptCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  journalEntry JournalEntry? @relation("ReceiptJournal", fields: [journalEntryId], references: [id])

  @@index([receiptDate])
  @@index([customerId])
  @@map("receipts")
}

// ─── Purchase Invoice (Hóa đơn mua vào) ───────────────────────────────────────

model PurchaseInvoice {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  voucherNumber  String   @unique @map("voucher_number") @db.VarChar(30)
  voucherDate    DateTime @map("voucher_date") @db.Date
  accountingDate DateTime @map("accounting_date") @db.Date
  supplierId     String   @map("supplier_id") @db.Uuid
  description    String?

  // Amounts
  totalAmount Decimal @default(0) @map("total_amount") @db.Decimal(18, 2)
  vatAmount   Decimal @default(0) @map("vat_amount") @db.Decimal(18, 2)
  grandTotal  Decimal @default(0) @map("grand_total") @db.Decimal(18, 2)

  // Supplier invoice info
  invoiceNumber String?   @map("invoice_number") @db.VarChar(30)
  invoiceSeries String?   @map("invoice_series") @db.VarChar(10)
  invoiceDate   DateTime? @map("invoice_date") @db.Date

  // Posting
  isPosted   Boolean   @default(false) @map("is_posted")
  postedAt   DateTime? @map("posted_at")
  postedById String?   @map("posted_by_id") @db.Uuid

  // Payment terms
  paymentTermDays Int?      @map("payment_term_days")
  dueDate         DateTime? @map("due_date") @db.Date

  // Extra
  contactPerson String? @map("contact_person") @db.VarChar(120)
  reference     String? @db.VarChar(80)
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  supplier       Partner                 @relation("PurchaseInvoiceSupplier", fields: [supplierId], references: [id])
  postedBy       UserProfile?            @relation("PurchaseInvoicePostedBy", fields: [postedById], references: [id], onDelete: SetNull)
  details        PurchaseInvoiceDetail[]
  journalEntries JournalEntry[]

  @@index([voucherDate])
  @@index([accountingDate])
  @@index([supplierId])
  @@index([isPosted])
  @@index([supplierId, isPosted, dueDate], name: "idx_pi_supplier_debt_query")
  @@map("purchase_invoices")
}

model PurchaseInvoiceDetail {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  itemId      String  @map("item_id") @db.Uuid
  warehouseId String? @map("warehouse_id") @db.Uuid
  description String? @db.VarChar(255)
  qty         Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @map("unit_price") @db.Decimal(18, 2)
  vatRate     Decimal @default(0) @map("vat_rate") @db.Decimal(5, 2)
  amount      Decimal @db.Decimal(18, 2)

  // Accounts – payable (331) and expense/inventory (156/152/641…)
  apAccountId  String? @map("ap_account_id") @db.Uuid
  expAccountId String? @map("exp_account_id") @db.Uuid

  sortOrder Int @default(0) @map("sort_order")

  invoice    PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item       Item            @relation("PurchaseItem", fields: [itemId], references: [id])
  warehouse  Warehouse?      @relation("PurchaseWarehouse", fields: [warehouseId], references: [id], onDelete: SetNull)
  apAccount  Account?        @relation("ApAccount", fields: [apAccountId], references: [id], onDelete: SetNull)
  expAccount Account?        @relation("ExpAccount", fields: [expAccountId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([itemId])
  @@map("purchase_invoice_details")
}

// ─── Payment (Chi tiền trả NCC) ───────────────────────────────────────────────

model Payment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentNumber  String   @unique @map("payment_number") @db.VarChar(30)
  paymentDate    DateTime @map("payment_date") @db.Date
  accountingDate DateTime @map("accounting_date") @db.Date
  supplierId     String   @map("supplier_id") @db.Uuid
  recipient      String?  @db.VarChar(120) // Người nhận
  reason         String?  @db.VarChar(255) // Lý do chi
  totalAmount    Decimal  @default(0) @map("total_amount") @db.Decimal(18, 2)
  notes          String?
  journalEntryId String?  @unique @map("journal_entry_id") @db.Uuid
  createdById    String?  @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  supplier     Partner       @relation("PaymentSupplier", fields: [supplierId], references: [id])
  createdBy    UserProfile?  @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  journalEntry JournalEntry? @relation("PaymentJournal", fields: [journalEntryId], references: [id])

  @@index([paymentDate])
  @@index([supplierId])
  @@map("payments")
}

// ─── Accounting Periods & Opening Balances ────────────────────────────────────

model AccountingPeriod {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year       Int
  month      Int // 1-12
  status     PeriodStatus @default(OPEN)
  closedAt   DateTime?    @map("closed_at")
  closedById String?      @map("closed_by_id") @db.Uuid
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  closedBy UserProfile? @relation("PeriodClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  @@unique([year, month])
  @@index([status])
  @@map("accounting_periods")
}

model AccountOpeningBalance {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  year         Int
  month        Int
  accountId    String   @map("account_id") @db.Uuid
  debitAmount  Decimal  @default(0) @map("debit_amount") @db.Decimal(18, 2)
  creditAmount Decimal  @default(0) @map("credit_amount") @db.Decimal(18, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([year, month, accountId])
  @@index([year, month])
  @@map("account_opening_balances")
}
